---
import '../styles/global.css';
import MobileNav from '../components/MobileNav.tsx';
import ThemeToggle from '../components/ThemeToggle.tsx';
import profile from '../data/home/profile.json';

interface Props {
	title: string;
}

const { title } = Astro.props;

const resumeHref = import.meta.env.BASE_URL.replace(/\/$/, '') + profile.resumeUrl;

// SVG paths keyed by platform — add new platforms here as needed
const socialIcons: Record<string, string> = {
