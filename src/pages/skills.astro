---
import Layout from '../layouts/Layout.astro';
import SkillsArchitecture from '../components/SkillsArchitecture.tsx';
import { Layers } from 'lucide-react';
import profile from '../data/home/profile.json';
---

<Layout title={`Skills Architecture | ${profile.name}`}>
    <div class="min-h-screen bg-slate-50 dark:bg-slate-950 flex flex-col items-center overflow-hidden relative transition-colors duration-500">
        
        <div class="w-full flex justify-center overflow-visible mt-0 h-auto">
            <SkillsArchitecture client:only="react" />
        </div>

    </div>
</Layout>
